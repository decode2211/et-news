{
  "name": "news-app-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"next,fastapi\" -c \"cyan,green\" \"npm run frontend\" \"npm run backend\"",
    "frontend": "npm run dev --prefix frontend",
    "backend": "cd backend && python -m uvicorn app.main:app --reload --port 8000",
    "install:all": "npm install && npm install --prefix frontend",
    "setup:python": "cd backend && python -m venv venv && ./venv/bin/activate && pip install -r requirements.txt"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}